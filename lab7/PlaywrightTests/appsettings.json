{
  "Playwright": {
    "BrowserType": "chromium",
    "HeadlessMode": true,
    "Timeout": 30000,
    "SlowMoDelay": 0,
    "FullPage": false,
    "ViewportWidth": 1920,
    "ViewportHeight": 1080,
    "LaunchArgs": [
      "--disable-blink-features=AutomationControlled",
      "--start-maximized"
    ]
  },
  "Environments": {
    "Default": "dev",
    "Urls": {
      "dev": "https://www.saucedemo.com",
      "staging": "https://staging.saucedemo.com",
      "production": "https://www.saucedemo.com"
    }
  },
  "Logging": {
    "MinimumLevel": "Information",
    "WriteTo": [ "Console", "File" ],
    "FilePath": "Logs/test-{Date:yyyy-MM-dd}.log",
    "OutputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
  },
  "Allure": {
    "Enabled": true,
    "ResultsDirectory": "allure-results",
    "CleanBeforeRun": true
  },
  "TestData": {
    "DefaultTimeout": 5,
    "RetryAttempts": 3,
    "Screenshots": true,
    "Videos": false
  }
}